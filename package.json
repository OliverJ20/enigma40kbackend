{
  "name": "wh40k-lists-backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Hono API for the Dossier Warhammer 40k list service. Deploys to Cloud Run.",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "tsx watch --env-file .env src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "auth:generate": "npx @better-auth/cli generate --output src/db/auth-schema.ts",
    "docker:build": "docker build -t wh40k-lists-backend .",
    "docker:run": "docker run --env-file .env -p 8080:8080 wh40k-lists-backend"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.1",
    "@neondatabase/serverless": "^0.10.1",
    "better-auth": "^1.1.4",
    "drizzle-orm": "^0.45.2",
    "fast-xml-parser": "^4.5.0",
    "hono": "^4.6.10",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.13.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
